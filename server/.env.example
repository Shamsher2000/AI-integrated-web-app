NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:4173
CLIENT_URLS=http://localhost:5173,http://localhost:4173
MONGO_URI=mongodb://127.0.0.1:27017/mern-ai-assistant
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=12h

# ============================================
# AI Provider Configuration
# ============================================
# Supported providers: 'groq', 'openai', 'huggingface'
# Change this to switch between different AI providers
AI_PROVIDER=groq

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_TOKENS=2000

# HuggingFace Configuration
# Get your API key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct:novita
HUGGINGFACE_MAX_TOKENS=2000

# Groq Configuration
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_TOKENS=2000

# Chat Configuration
MAX_CHAT_HISTORY=12
MAX_CONTENT_LENGTH=6000
